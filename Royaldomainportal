<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>RoyalDomain Portal</title>

    <style>
        body {
            margin: 0;
            padding: 0;
            background: #0b0b0f;
            color: #f5f5f5;
            font-family: "Cinzel", serif;
        }

        /* HERO SECTION */
        .hero {
            text-align: center;
            padding: 80px 20px;
            background: linear-gradient(180deg, #1a1a22, #0b0b0f);
            border-bottom: 2px solid gold;
        }

        .hero img {
            width: 260px;
            margin-bottom: 20px;
        }

        .hero h1 {
            font-size: 3rem;
            color: gold;
            text-shadow: 0 0 12px rgba(255,215,0,0.6);
            margin: 10px 0;
        }

        .hero p {
            font-size: 1.3rem;
            opacity: 0.85;
        }

        /* SEARCH BAR */
        .search-section {
            text-align: center;
            padding: 40px 20px;
        }

        .search-box {
            width: 80%;
            max-width: 500px;
            padding: 14px 18px;
            border-radius: 8px;
            border: 1px solid gold;
            background: #111;
            color: #fff;
            font-size: 1rem;
        }

        /* CATEGORY GRID */
        .domain-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 30px;
            padding: 60px 40px;
        }

        .domain-card {
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,215,0,0.4);
            padding: 25px;
            border-radius: 12px;
            text-align: center;
            transition: 0.3s;
        }

        .domain-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 0 20px rgba(255,215,0,0.3);
        }

        .domain-title {
            font-size: 1.6rem;
            color: gold;
            margin-bottom: 10px;
        }

        /* FOOTER */
        footer {
            text-align: center;
            padding: 40px;
            border-top: 1px solid rgba(255,215,0,0.3);
            opacity: 0.7;
            font-size: 0.9rem;
        }
    </style>
</head>

<body>

<!-- HERO -->
<section class="hero">
    <img src="royaldomain-crest.png" alt="RoyalDomain Crest">
    <h1>RoyalDomain Portal</h1>
    <p>Acquire Elite Domain Names</p>
</section>

<!-- SEARCH -->
<section class="search-section">
    <input type="text" class="search-box" placeholder="Search premium domains...">
</section>

<!-- CATEGORY GRID -->
<section class="domain-grid">
    <div class="domain-card">
        <div class="domain-title">.DIAMONDS</div>
        <p>Premium gem‑grade domains for luxury brands.</p>
    </div>

    <div class="domain-card">
        <div class="domain-title">.RUBY</div>
        <p>High‑value digital assets with royal energy.</p>
    </div>

    <div class="domain-card">
        <div class="domain-title">.JEWELS</div>
        <p>Perfect for boutiques, collectors, and curators.</p>
    </div>

    <div class="domain-card">
        <div class="domain-title">.LUXURY</div>
        <p>Elite domains for high‑end enterprises.</p>
    </div>

    <div class="domain-card">
        <div class="domain-title">.GEMS</div>
        <p>Rare, radiant, and unforgettable digital identities.</p>
    </div>
</section>

<!-- FOOTER -->
<footer>
    © 2026 RoyalDomain — All Rights Reserved
</footer>

</body>
</html>
